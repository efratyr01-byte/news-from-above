    fortunes[Math.floor(Math.random() * fortunes.length)];

  const overlay = document.getElementById("fortuneOverlay");
  const text = document.getElementById("fortuneText");

  text.textContent = randomFortune;
  overlay.style.display = "flex";

}, 3000);
const d = today.getDate().toString().padStart(2, '0');
const m = (today.getMonth() + 1).toString().padStart(2, '0');
const y = today.getFullYear().toString().slice(-2);

document.getElementById("date").textContent = `${d}.${m}.${y}`;

});
